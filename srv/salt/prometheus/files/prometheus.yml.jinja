global:
  scrape_interval: {{ scrape_interval }}
  evaluation_interval: {{ evaluation_interval }}

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node'
    static_configs:
      - targets: ['{{ node_exporter_ip }}:9100']

  - job_name: 'mysql'
    static_configs:
      - targets: ['{{ mysql_exporter_ip }}:9104']

  - job_name: 'redis'
    static_configs:
      - targets: ['{{ redis_exporter_ip }}:9100']

  - job_name: 'nginx'
    metrics_path: /health
    static_configs:
      - targets: ['{{ nginx_ip }}:80']

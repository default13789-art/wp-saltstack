#!/usr/bin/env bash
set -euo pipefail

SECRETS_FILE="{{ secrets_file }}"
AGE_KEY_FILE="{{ age_key_file }}"
AGE_PUB_FILE="{{ age_pub_file }}"
SOPS_CONFIG="{{ sops_config }}"

usage() {
    echo "Usage: wp-secrets <command>"
    echo ""
    echo "Commands:"
    echo "  encrypt    Encrypt secrets.sls with SOPS + age"
    echo "  decrypt    Decrypt secrets.sls for editing"
    echo "  status     Show encryption status of secrets.sls"
    echo "  pubkey     Show the age public key"
    echo "  view       Decrypt and print secrets.sls to stdout"
    exit 1
}

[ $# -lt 1 ] && usage

case "$1" in
    encrypt)
        if grep -q 'sops:' "$SECRETS_FILE" 2>/dev/null; then
            echo "Already encrypted."
            exit 0
        fi
        PUB_KEY=$(cat "$AGE_PUB_FILE")
        SOPS_AGE_KEY_FILE="$AGE_KEY_FILE" sops --encrypt --age "$PUB_KEY" --in-place "$SECRETS_FILE"
        echo "Encrypted: $SECRETS_FILE"
        ;;
    decrypt)
        if ! grep -q 'sops:' "$SECRETS_FILE" 2>/dev/null; then
            echo "Already decrypted."
            exit 0
        fi
        SOPS_AGE_KEY_FILE="$AGE_KEY_FILE" sops --decrypt --in-place "$SECRETS_FILE"
        echo "Decrypted: $SECRETS_FILE"
        ;;
    status)
        if [ ! -f "$SECRETS_FILE" ]; then
            echo "NOT FOUND: $SECRETS_FILE"
        elif grep -q 'sops:' "$SECRETS_FILE" 2>/dev/null; then
            echo "ENCRYPTED: $SECRETS_FILE"
        else
            echo "PLAINTEXT: $SECRETS_FILE"
        fi
        ;;
    pubkey)
        cat "$AGE_PUB_FILE"
        ;;
    view)
        if grep -q 'sops:' "$SECRETS_FILE" 2>/dev/null; then
            SOPS_AGE_KEY_FILE="$AGE_KEY_FILE" sops --decrypt "$SECRETS_FILE"
        else
            cat "$SECRETS_FILE"
        fi
        ;;
    *)
        usage
        ;;
esac
